<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#AA468EE3" /> <!-- Semi-transparent color -->
            <corners android:radius="8dp" />
        </shape>
    </item>

    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#468EE3" /> <!-- Original button color -->
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
