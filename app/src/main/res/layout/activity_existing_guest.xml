<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E2E2E2">

    <!-- Title for Guest Log In -->
    <TextView
        android:id="@+id/LoginGuestTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        android:text=" Log In"
        android:textColor="#333333"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Email Input for Guest -->
    <EditText
        android:id="@+id/emailInputLoginGuest"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="32dp"
        android:background="@drawable/rounded_edittext"
        android:hint="Email"
        android:inputType="textEmailAddress"
        android:padding="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/LoginGuestTitle" />

    <!-- Password Input for Guest -->
    <EditText
        android:id="@+id/passwordInputLoginGuest"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="32dp"
        android:background="@drawable/rounded_edittext"
        android:hint="Password"
        android:inputType="textPassword"
        android:padding="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/emailInputLoginGuest" />

    <!-- Forgot Password clickable text -->

    <!-- Log In Button for Guest -->

    <TextView
        android:id="@+id/ForgotGuest"
        android:layout_width="117dp"
        android:layout_height="41dp"
        android:layout_marginTop="144dp"
        android:clickable="true"
        android:focusable="true"
        android:text="Forgot Password?"
        android:textAlignment="center"
        android:textColor="#468EE3"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/passwordInputLoginGuest" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/LoginButtonGuest"
        android:layout_width="351dp"
        android:layout_height="49dp"
        android:layout_marginTop="304dp"
        android:text="Log In"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        app:backgroundTint="#468EE3"
        app:cornerRadius="28dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
